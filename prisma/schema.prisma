generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  password      String?
  role          Role          @default(USER)
  accounts      Account[]
  invitations   Invitation[]
  sessions      Session[]
  transactions  Transaction[]
  promoUsages   PromoUsage[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// ── Invitation ────────────────────────────────────────────────
// NOTE: schedule, loveStory, digitalGifts, photoUrls are now
// normalized into separate relational tables (v1.2).
// headerPhotoUrl, groomPhotoUrl, bridePhotoUrl remain as direct
// fields because they serve a distinct role-based purpose.

model Invitation {
  id             String    @id @default(cuid())
  groomName      String
  groomParents   String?
  brideName      String
  brideParents   String?
  eventDate      DateTime
  eventTime      String
  venueName      String
  venueAddress   String
  greeting       String
  mainBody       String
  eventInfo      String
  closing        String
  fullText       String
  tone           String    @default("formal")
  language       String    @default("id")
  slug           String    @unique @default(cuid())
  viewCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  headerPhotoUrl String?
  groomPhotoUrl  String?
  bridePhotoUrl  String?
  userId         String
  musicUrl       String?
  videoUrl       String?
  layout         String    @default("elegant-cream")
  quotes         String?
  /// Tier reflects the current ACTIVE plan of this invitation.
  /// Source of truth: Transaction.status === SUCCESS && Transaction.tier
  /// isPaid is REMOVED — derive payment status from transactions relation.
  tier           Tier      @default(DRAFT)
  aiRegenCount   Int       @default(0)
  qrEnabled      Boolean   @default(true)
  expiresAt      DateTime?
  deletedAt      DateTime?
  status         InvitationStatus @default(DRAFT)


  // Relations
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests       Guest[]
  transactions Transaction[]
  events       InvitationEvent[]
  stories      InvitationStory[]
  gifts        InvitationGift[]
  photos       InvitationPhoto[]

  @@index([slug])
  @@index([userId])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([tier])
}

// ── Normalized: Schedule Events ──────────────────────────────
model InvitationEvent {
  id           String     @id @default(cuid())
  invitationId String
  label        String
  time         String
  icon         String     @default("heart")
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
}

// ── Normalized: Love Story ────────────────────────────────────
model InvitationStory {
  id           String     @id @default(cuid())
  invitationId String
  year         String
  title        String
  description  String
  photoUrl     String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
}

// ── Normalized: Digital Gifts ─────────────────────────────────
model InvitationGift {
  id            String     @id @default(cuid())
  invitationId  String
  bankName      String
  accountNumber String
  accountHolder String
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
}

// ── Normalized: Photos ────────────────────────────────────────
model InvitationPhoto {
  id           String     @id @default(cuid())
  invitationId String
  url          String
  type         PhotoType  @default(GALLERY)
  altText      String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@index([type])
}

// ── Guest ─────────────────────────────────────────────────────
model Guest {
  id           String     @id @default(cuid())
  invitationId String
  name         String
  email        String?
  phone        String?
  rsvpStatus   RsvpStatus @default(PENDING)
  message      String?
  attendees    Int        @default(1)
  checkedIn    Boolean    @default(false)
  isVip        Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@index([rsvpStatus])
}

// ── Transaction ───────────────────────────────────────────────
// id = orderId (format: ORD-YYYYMMDD-XXXX) — serves as the human-readable order number.
// idempotencyKey ensures no duplicate checkout sessions are created for the same intent.

model Transaction {
  id             String            @id // ORD-YYYYMMDD-XXXX (human-readable order number)
  idempotencyKey String            @unique
  userId         String
  invitationId   String?
  amount         Int
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  tier           Tier?
  paymentUrl     String?
  midtransId     String?           @unique
  paymentMethod  String? // gopay, bank_transfer, credit_card, etc.
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  promoCode      String?
  discountAmount Int               @default(0)

  // Relations
  invitation Invitation?          @relation(fields: [invitationId], references: [id])
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  promo      Promo?               @relation(fields: [promoCode], references: [code])
  webhooks   PaymentWebhook[]
  history    TransactionHistory[]
  promoUsage PromoUsage?

  @@index([userId])
  @@index([invitationId])
  @@index([status])
  @@index([idempotencyKey])
}

// ── Payment Webhook Log (Idempotency) ─────────────────────────
// Every raw Midtrans notification is stored here.
// midtransNotifId is the unique notification identifier used to prevent double-processing.

model PaymentWebhook {
  id              String      @id @default(cuid())
  transactionId   String
  rawPayload      Json
  midtransNotifId String      @unique // Idempotency: <order_id>:<transaction_status>
  processedAt     DateTime    @default(now())
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

// ── Transaction Status History (Audit Trail) ──────────────────
// Every status change is recorded here for debugging and accountants.

model TransactionHistory {
  id            String      @id @default(cuid())
  transactionId String
  oldStatus     String
  newStatus     String
  /// Who triggered the change: WEBHOOK | RECONCILER | ADMIN | SYSTEM
  changedBy     String
  metadata      Json? // Optional: raw midtrans data, IP address, etc.
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([createdAt])
}

// ── Enums ─────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Tier {
  DRAFT
  BASIC
  PREMIUM
  ULTIMATE
}

enum TransactionStatus {
  PENDING
  WAITING_PAYMENT
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum InvitationStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ACTIVE
  EXPIRED
  SUSPENDED
  DELETED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TransactionType {
  INVITATION_UPGRADE
  ACCOUNT_UPGRADE
}

enum RsvpStatus {
  PENDING
  ATTENDING
  NOT_ATTENDING
}

enum PhotoType {
  GALLERY // General gallery photos
  PREWEDDING // Prewedding specific photos
}

// ── Promos & Vouchers ─────────────────────────────────────────

model Promo {
  id                String       @id @default(cuid())
  code              String       @unique
  description       String?
  discountPercent   Int          @default(0) // 1-100%
  maxDiscountAmount Int?         // Opsional: Maksimal diskon dalam Rupiah
  maxGlobalUsage    Int          @default(0) // 0 = unlimited
  usageCount        Int          @default(0)
  usageLimitPerUser Int          @default(1)
  usageLimitPerIp   Int          @default(1)
  isActive          Boolean      @default(true)
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  transactions Transaction[]
  usages       PromoUsage[]

  @@index([code])
  @@index([isActive])
}

model PromoUsage {
  id            String      @id @default(cuid())
  promoCode     String
  userId        String
  transactionId String      @unique
  ipAddress     String
  createdAt     DateTime    @default(now())

  promo         Promo       @relation(fields: [promoCode], references: [code], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([promoCode])
  @@index([userId])
  @@index([ipAddress])
}

// ── ERP Expansion (Admin) ─────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  date        DateTime        @default(now())
  category    ExpenseCategory
  description String
  amount      Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([category])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  source    LeadSource
  status    LeadStatus @default(NEW)
  date      DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([date])
  @@index([source])
  @@index([status])
}

model MarketingSpend {
  id        String     @id @default(cuid())
  channel   LeadSource
  amount    Int
  date      DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([date])
  @@index([channel])
}

enum ExpenseCategory {
  INFRASTRUCTURE
  MARKETING
  PAYROLL
  SOFTWARE
  OPERATIONAL
  OTHER
}

enum LeadSource {
  INSTAGRAM
  TIKTOK
  GOOGLE
  REFERRAL
  WHATSAPP
  ORGANIC
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO
  NEGOTIATION
  WON
  LOST
}

// ── Background Jobs ───────────────────────────────────────────
model BackgroundJob {
  jobId     String    @id @default(cuid())
  type      String
  status    JobStatus @default(PENDING)
  progress  Int       @default(0)
  result    Json?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
}

// ── Audit Logs ────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actorId   String
  entityId  String
  entity    String
  details   Json?
  timestamp DateTime @default(now())

  @@index([actorId])
  @@index([entityId])
  @@index([action])
}

// ── AI Generation Cache ───────────────────────────────────────
model AiCache {
  id        String   @id @default(cuid())
  hash      String   @unique
  response  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hash])
}

// ── Theme Templates ───────────────────────────────────────────
model ThemeTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  thumbnail   String?
  category    String   @default("Modern")
  isPremium   Boolean  @default(false)
  config      Json     // Stores JSON configuration of style, layouts, and custom CSS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
}
